---
interface Props {
  id?: string;
  text?: string;
  icon?: boolean;
}

const {
  id = "free-scan-button",
  text = "Ask for a Free Scan",
  icon = true,
} = Astro.props;
---

<div class="floating-cta-wrapper">
  <!-- Main button -->
  <button
    id={id}
    class="floating-cta-button"
    aria-label={text}
  >
    <!-- Shine effect overlay -->
    <span class="shine-overlay"></span>
    
    <!-- Icon with rotation animation -->
    {
      icon && (
        <span class="icon-wrapper">
          <svg
            class="button-icon"
            fill="currentColor"
            viewBox="0 0 20 20"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
            <path
              fill-rule="evenodd"
              d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      )
    }
    
    <!-- Text content -->
    <span class="button-text">{text}</span>
  </button>
</div>

<style>
  .floating-cta-wrapper {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 40;
    animation: slide-bounce-in 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) 0.5s both;
  }

  /* Main button */
  .floating-cta-button {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    background: linear-gradient(135deg, #137886 0%, #0e5f6a 100%);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    box-shadow: 
      0 10px 30px rgba(19, 120, 134, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
      0 0 20px rgba(19, 120, 134, 0.3);
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
    backface-visibility: hidden;
  }

  .floating-cta-button:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 
      0 15px 40px rgba(19, 120, 134, 0.5),
      0 0 0 2px rgba(255, 255, 255, 0.2) inset,
      0 0 30px rgba(19, 120, 134, 0.4);
    border-color: rgba(255, 255, 255, 0.4);
    animation: pulse-ring 1.5s ease-out infinite;
  }

  @keyframes pulse-ring {
    0% {
      box-shadow: 
        0 15px 40px rgba(19, 120, 134, 0.5),
        0 0 0 2px rgba(255, 255, 255, 0.2) inset,
        0 0 30px rgba(19, 120, 134, 0.4),
        0 0 0 0 rgba(19, 120, 134, 0.7);
    }
    50% {
      box-shadow: 
        0 15px 40px rgba(19, 120, 134, 0.5),
        0 0 0 2px rgba(255, 255, 255, 0.2) inset,
        0 0 30px rgba(19, 120, 134, 0.4),
        0 0 0 10px rgba(19, 120, 134, 0);
    }
    100% {
      box-shadow: 
        0 15px 40px rgba(19, 120, 134, 0.5),
        0 0 0 2px rgba(255, 255, 255, 0.2) inset,
        0 0 30px rgba(19, 120, 134, 0.4),
        0 0 0 0 rgba(19, 120, 134, 0);
    }
  }

  .floating-cta-button:active {
    transform: translateY(-2px) scale(1.02);
  }

  /* Shine effect overlay */
  .shine-overlay {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
    transition: left 0.5s;
  }

  .floating-cta-button:hover .shine-overlay {
    left: 100%;
  }

  /* Icon wrapper with rotation */
  .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .button-icon {
    width: 1.5rem;
    height: 1.5rem;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
    animation: icon-bounce 2s ease-in-out infinite;
  }

  .floating-cta-button:hover .button-icon {
    animation: icon-spin 0.6s ease-in-out;
  }

  /* Button text */
  .button-text {
    position: relative;
    z-index: 1;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    letter-spacing: 0.025em;
  }

  /* Hide text on mobile, show icon only */
  @media (max-width: 768px) {
    .button-text {
      display: none;
    }

    .floating-cta-button {
      padding: 1rem;
      border-radius: 50%;
      width: 3.5rem;
      height: 3.5rem;
      justify-content: center;
    }

    .icon-wrapper {
      width: 1.75rem;
      height: 1.75rem;
    }

    .button-icon {
      width: 1.75rem;
      height: 1.75rem;
    }
  }

  /* Animations */
  @keyframes slide-bounce-in {
    0% {
      opacity: 0;
      transform: translateX(150px);
    }
    60% {
      opacity: 1;
      transform: translateX(-10px);
    }
    80% {
      transform: translateX(5px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pulse-animation {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.6;
    }
    50% {
      opacity: 0.3;
  @keyframes slide-bounce-in {
    0% {
      opacity: 0;
      transform: translateX(150px);
    }
    60% {
      opacity: 1;
      transform: translateX(-10px);
    }
    80% {
      transform: translateX(5px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  @keyframes icon-spin {
    0% {
      transform: rotate(0deg) scale(1);
    }
    50% {
      transform: rotate(180deg) scale(1.2);
    }
    100% {
      transform: rotate(360deg) scale(1);
    }
  }

  /* Responsive adjustments */
      height: 1.25rem;
    }

    .button-icon {
      width: 1.25rem;
      height: 1.25rem;
    }

    .sparkle {
      font-size: 0.75rem;
    }
  }

  /* Accessibility - Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .floating-cta-wrapper {
      animation: none;
    }

    .button-icon {
      animation: none !important;
    }

    .floating-cta-button:hover {
      transform: scale(1.02);
    }
  }