---
import PageLayout from "~/layouts/PageLayout.astro";
import SectionRenderer from "~/components/sections/SectionRenderer.astro";

import screenAdvertisingData from "~/data/pages/screen-advertising.json";
import becomeAVenuePartnerData from "~/data/pages/become-a-venue-partner.json";
import billboardLocationsData from "~/data/pages/billboard-locations.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";

const dataMap: Record<string, any> = localizeData({
  "screen-advertising": screenAdvertisingData,
  "become-a-venue-partner": becomeAVenuePartnerData,
  "locations": billboardLocationsData,
});

const SERVICE_TYPE: Record<string, string> = {
  "screen-advertising": "Indoor Digital Billboard Advertising",
  "become-a-venue-partner": "Venue Partner Network",
  "locations": "Indoor Billboard Network",
};

export function getStaticPaths() {
  return [
    { params: { slug: "screen-advertising" } },
    { params: { slug: "become-a-venue-partner" } },
    { params: { slug: "locations" } },
  ];
}

const { slug } = Astro.params;
const entry = dataMap[slug!];

const { metadata, extraSchemas } = buildPageMeta(entry, {
  service: {
    url: `/indoor-billboards/${slug}`,
    serviceType: SERVICE_TYPE[slug!],
  },
});
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  <SectionRenderer sections={entry.sections} />
</PageLayout>
