---
import PageLayout from "~/layouts/PageLayout.astro";
import SectionRenderer from "~/components/sections/SectionRenderer.astro";

import contactDataRaw from "~/data/pages/main/contact-us.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";
const contactData = localizeData(contactDataRaw);
const { sections } = contactData;

const { metadata, extraSchemas } = buildPageMeta(contactData);
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  <SectionRenderer sections={sections} />
</PageLayout>
