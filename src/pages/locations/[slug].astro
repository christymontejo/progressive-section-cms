---
import PageLayout from "~/layouts/PageLayout.astro";
import Hero from "~/components/sections/Hero.astro";
import FAQs from "~/components/sections/FAQs.astro";
import ContentWithImage from "~/components/sections/ContentWithImage.astro";
import FeaturesSection from "~/components/sections/FeaturesSection.astro";
import FeaturesWithImage from "~/components/sections/FeaturesWithImage.astro";
import Benefits from "~/components/sections/Benefits.astro";
import Map from "~/components/sections/MapSection.astro";

import arvadaData from "~/data/locations/arvada.json";
import auroraData from "~/data/locations/aurora.json";
import centennialData from "~/data/locations/centennial.json";
import lakewoodData from "~/data/locations/lakewood.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";

const dataMap: Record<string, any> = localizeData({
  arvada: arvadaData,
  aurora: auroraData,
  centennial: centennialData,
  lakewood: lakewoodData,
});

export function getStaticPaths() {
  return [
    { params: { slug: "arvada" } },
    { params: { slug: "aurora" } },
    { params: { slug: "centennial" } },
    { params: { slug: "lakewood" } },
  ];
}

const { slug } = Astro.params;
const entry = dataMap[slug!];
const locName = entry.location || "";

// Recursively substitute {location} token in all string values
function swapLocation(v: any): any {
  if (typeof v === "string") return v.replaceAll("{location}", locName);
  if (Array.isArray(v)) return v.map(swapLocation);
  if (v && typeof v === "object") {
    return Object.fromEntries(
      Object.entries(v).map(([k, x]) => [k, swapLocation(x)])
    );
  }
  return v;
}
const pageData = swapLocation(entry);

const sections = (pageData.sections || []).sort(
  (a: any, b: any) => (a.order || 0) - (b.order || 0)
);

// Filter self from Map locations
const filterSelf = (locs: any[]) =>
  (locs || []).filter((loc: any) => {
    const n = typeof loc === "string" ? loc : loc?.name;
    return n && n.toLowerCase() !== locName.toLowerCase();
  });

const { metadata, extraSchemas } = buildPageMeta(pageData, {
  city: { city: locName, url: `/locations/${slug}` },
  extras: { location: locName },
});
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  {
    sections.map((section: any) => {
      if (section.section === "Hero") {
        return (
          <Hero
            eyebrow={section.eyebrow}
            title={section.title}
            description={section.description}
            image={section.image}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
          />
        );
      }

      if (section.section === "Benefits") {
        return (
          <Benefits
            title={section.title}
            description={section.description}
            benefits={section.benefits}
          />
        );
      }

      if (section.section === "FAQs" && section.faqs) {
        return (
          <FAQs
            title={section.title}
            description={section.description}
            faqs={section.faqs}
          />
        );
      }

      if (section.section === "ContentWithImage") {
        return (
          <ContentWithImage
            title={section.title}
            eyebrow={section.eyebrow}
            description={section.description}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            image={section.image}
            imagePosition={section.imagePosition}
            background={section.background}
          />
        );
      }

      if (
        section.section === "FeaturesWithImage" ||
        section.section === "FeaturesSection"
      ) {
        if (!section.features) return null;

        if (section.section === "FeaturesWithImage") {
          return (
            <FeaturesWithImage
              eyebrow={section.eyebrow}
              title={section.title}
              description={section.description}
              cards={section.features}
              ctaText={section.ctaText}
              ctaLink={section.ctaLink}
            />
          );
        }

        return (
          <FeaturesSection
            eyebrow={section.eyebrow}
            title={section.title}
            description={section.description}
            features={section.features}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
          />
        );
      }

      if (section.section === "Map" || section.section === "MapSection") {
        return (
          <Map
            title={section.title}
            eyebrow={section.eyebrow}
            description={section.description}
            mapUrl={section.mapUrl}
            locations={filterSelf(section.locations)}
            viewMode={section.viewMode}
            background={section.background}
          />
        );
      }

      return null;
    })
  }
</PageLayout>
