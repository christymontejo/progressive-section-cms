---
import Button from "../ui/Button.astro";

interface Card {
  title?: string;
  description?: string;
  icon?: string;
  image?: string;
}

interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  cards: Card[];
  ctaText?: string;
  ctaLink?: string;
  background?: "white" | "light" | "primary";
  isCarousel?: boolean;
  itemsPerSlide?: number;
  carouselAutoplay?: boolean;
  carouselAutoplayDelay?: number;
}

const {
  title,
  eyebrow,
  description,
  cards = [],
  ctaText,
  ctaLink,
  background = "white",
  isCarousel = false,
  itemsPerSlide = 2,
  carouselAutoplay = false,
  carouselAutoplayDelay = 5000,
} = Astro.props;

const bgClasses = {
  white: "bg-white",
  light: "bg-neutral",
  primary: "bg-primary",
};

const textColorClasses = {
  white: "text-primary",
  light: "text-primary",
  primary: "text-white",
};

const descriptionColorClasses = {
  white: "text-primary-dark",
  light: "text-primary-dark",
  primary: "text-neutral",
};

// Adaptive grid based on card count (max 3 columns)
const getGridCols = (count: number) => {
  if (count === 1) return "grid-cols-1 max-w-2xl mx-auto";
  if (count === 2) return "grid-cols-1 md:grid-cols-2 max-w-5xl mx-auto";
  if (count === 3) return "grid-cols-1 md:grid-cols-2 lg:grid-cols-3";
  if (count === 4) return "grid-cols-1 md:grid-cols-2";
  return "grid-cols-1 md:grid-cols-2 lg:grid-cols-3";
};

const gridCols = getGridCols(cards.length);
const carouselId = `carousel-${Math.random().toString(36).substring(2, 9)}`;
---

<section class={`py-16 md:py-24 ${bgClasses[background]} fade-in-section`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    {
      (eyebrow || title || description) && (
        <div class="max-w-3xl mx-auto text-center mb-16">
          {eyebrow && (
            <div class="flex items-center justify-center gap-3 mb-4">
              <div
                class={`h-px w-12 ${background === "primary" ? "bg-white/30" : "bg-primary-light"}`}
              />
              <span
                class={`section-eyebrow ${background === "primary" ? "text-white" : "text-primary-light"}`}
              >
                {eyebrow}
              </span>
              <div
                class={`h-px w-12 ${background === "primary" ? "bg-white/30" : "bg-primary-light"}`}
              />
            </div>
          )}

          {title && (
            <h2 class={`section-title mb-6 ${textColorClasses[background]}`}>
              {title}
            </h2>
          )}

          {description && (
            <p
              class={`section-description ${descriptionColorClasses[background]}`}
            >
              {description}
            </p>
          )}
        </div>
      )
    }

    {
      isCarousel ? (
        /* Carousel Mode */
        <div class="relative" style="position: relative;">
          {/* Navigation Buttons */}
          <button
            class="!absolute left-0 md:-left-16 w-12 h-12 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all z-10 bg-primary-dark text-white hover:bg-primary-darker hover:scale-110"
            style="position: absolute !important; top: 50%; transform: translateY(-50%);"
            data-carousel-prev
            aria-label="Previous"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            class="!absolute right-0 md:-right-16 w-12 h-12 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all z-10 bg-primary-dark text-white hover:bg-primary-darker hover:scale-110"
            style="position: absolute !important; top: 50%; transform: translateY(-50%);"
            data-carousel-next
            aria-label="Next"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
          
          <div class="overflow-hidden" id={carouselId}>
            <div class="flex transition-transform duration-500 ease-in-out" data-carousel-track>
              {cards.map((card, index) => (
                <div class="flex-shrink-0 px-4" style={`width: ${100 / itemsPerSlide}%`}>
                  <div class="group h-full">
                    {card.image && (
                      <div class="relative rounded-2xl overflow-hidden mb-6">
                        <img
                          src={card.image}
                          alt={card.title || "Feature image"}
                          class="w-full aspect-[4/3] object-cover"
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="space-y-3">
                      <div
                        class={`inline-flex items-center justify-center w-10 h-10 rounded-lg text-lg font-bold ${
                          background === "primary"
                            ? "bg-white/10 text-white"
                            : "bg-primary text-white"
                        }`}
                      >
                        {(index + 1).toString().padStart(2, "0")}
                      </div>
                      {card.title && (
                        <h3
                          class={`text-xl md:text-2xl font-bold ${
                            background === "primary" ? "text-white" : "text-primary"
                          }`}
                          set:html={card.title.replace(/Step \d+<br>/gi, "")}
                        />
                      )}
                      {card.description && (
                        <p
                          class={`text-base leading-relaxed ${
                            background === "primary"
                              ? "text-neutral"
                              : "text-primary-dark"
                          }`}
                          set:html={card.description}
                        />
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Dots */}
          <div class="flex justify-center gap-2 mt-8">
            {Array.from({ length: Math.ceil(cards.length / itemsPerSlide) }).map((_, i) => (
              <button
                class={`w-3 h-3 rounded-full transition-all ${
                  i === 0
                    ? background === "primary"
                      ? "bg-white w-8"
                      : "bg-primary w-8"
                    : background === "primary"
                      ? "bg-white/30"
                      : "bg-primary/30"
                }`}
                data-carousel-dot={i}
                aria-label={`Go to slide ${i + 1}`}
              />
            ))}
          </div>
        </div>
      ) : (
        /* Grid Mode */
        <div class={`grid ${gridCols} gap-8`}>
          {cards.map((card, index) => (
            <div class="group">
              {card.image && (
                <div class="relative rounded-2xl overflow-hidden mb-6 shadow-[0_20px_60px_rgba(0,0,0,0.15)] group-hover:shadow-[0_25px_70px_rgba(0,0,0,0.25)] transition-all duration-500">
                  <img
                    src={card.image}
                    alt={card.title || "Feature image"}
                    class="w-full aspect-[4/3] object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="space-y-3">
                <div
                  class={`inline-flex items-center justify-center w-10 h-10 rounded-lg text-lg font-bold ${
                    background === "primary"
                      ? "bg-white/10 text-white"
                      : "bg-primary text-white"
                  }`}
                >
                  {(index + 1).toString().padStart(2, "0")}
                </div>
                {card.title && (
                  <h3
                    class={`text-xl md:text-2xl font-bold ${
                      background === "primary" ? "text-white" : "text-primary"
                    }`}
                    set:html={card.title.replace(/Step \d+<br>/gi, "")}
                  />
                )}
                {card.description && (
                  <p
                    class={`text-base leading-relaxed ${
                      background === "primary"
                        ? "text-neutral"
                        : "text-primary-dark"
                    }`}
                    set:html={card.description}
                  />
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }

    <!-- CTA Button -->
    {
      ctaText && ctaLink && (
        <div class="mt-12 text-center">
          <Button
            href={ctaLink}
            variant={background === "primary" ? "secondary" : "primary"}
            size="lg"
          >
            {ctaText}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </Button>
        </div>
      )
    }
  </div>
</section>

{isCarousel && (
  <script is:inline define:vars={{ carouselId, itemsPerSlide, autoplay: carouselAutoplay, autoplayDelay: carouselAutoplayDelay, totalCards: cards.length }}>
    function initCarousel() {
      const carousel = document.getElementById(carouselId);
      if (!carousel) return;

      const track = carousel.querySelector("[data-carousel-track]");
      const prevBtn = carousel.closest("section").querySelector("[data-carousel-prev]");
      const nextBtn = carousel.closest("section").querySelector("[data-carousel-next]");
      const dots = carousel.closest("section").querySelectorAll("[data-carousel-dot]");

      let currentIndex = 0;
      const totalSlides = Math.ceil(totalCards / itemsPerSlide);
      let autoplayInterval;

      function updateCarousel() {
        const offset = -(currentIndex * 100);
        track.style.transform = `translateX(${offset}%)`;

        dots.forEach((dot, index) => {
          if (index === currentIndex) {
            dot.classList.add("w-8");
            dot.classList.remove("bg-white/30", "bg-primary/30");
            dot.classList.add(dot.closest("section").classList.contains("bg-primary") ? "bg-white" : "bg-primary");
          } else {
            dot.classList.remove("w-8");
            dot.classList.add(dot.closest("section").classList.contains("bg-primary") ? "bg-white/30" : "bg-primary/30");
          }
        });
      }

      function goToSlide(index) {
        currentIndex = Math.max(0, Math.min(index, totalSlides - 1));
        updateCarousel();
        if (autoplay) {
          clearInterval(autoplayInterval);
          autoplayInterval = setInterval(nextSlide, autoplayDelay);
        }
      }

      function nextSlide() {
        goToSlide(currentIndex < totalSlides - 1 ? currentIndex + 1 : 0);
      }

      function prevSlide() {
        goToSlide(currentIndex > 0 ? currentIndex - 1 : totalSlides - 1);
      }

      prevBtn?.addEventListener("click", prevSlide);
      nextBtn?.addEventListener("click", nextSlide);
      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => goToSlide(index));
      });

      updateCarousel();
      if (autoplay) {
        autoplayInterval = setInterval(nextSlide, autoplayDelay);
        carousel.addEventListener("mouseenter", () => clearInterval(autoplayInterval));
        carousel.addEventListener("mouseleave", () => {
          autoplayInterval = setInterval(nextSlide, autoplayDelay);
        });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCarousel);
    } else {
      initCarousel();
    }
    document.addEventListener("astro:after-swap", initCarousel);
  </script>
)}
