---
import PageLayout from "~/layouts/PageLayout.astro";
import SectionRenderer from "~/components/sections/SectionRenderer.astro";

import designServicesData from "~/data/pages/solutions/foundational/design-services.json";
import googleBusinessProfileData from "~/data/pages/solutions/foundational/google-business-profile.json";
import socialMediaManagementData from "~/data/pages/solutions/foundational/social-media-management.json";
import websiteDesignData from "~/data/pages/solutions/foundational/website-design.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";

const dataMap: Record<string, any> = localizeData({
  "design-services": designServicesData,
  "google-business-profile": googleBusinessProfileData,
  "social-media-management": socialMediaManagementData,
  "website-design": websiteDesignData,
});

const SERVICE_TYPE: Record<string, string> = {
  "design-services": "Graphic Design",
  "google-business-profile": "Local SEO",
  "social-media-management": "Social Media Marketing",
  "website-design": "Web Design and Development",
};

export function getStaticPaths() {
  return [
    { params: { slug: "design-services" } },
    { params: { slug: "google-business-profile" } },
    { params: { slug: "social-media-management" } },
    { params: { slug: "website-design" } },
  ];
}

const { slug } = Astro.params;
const entry = dataMap[slug!];

const { metadata, extraSchemas } = buildPageMeta(entry, {
  service: {
    url: `/solutions/foundational/${slug}`,
    serviceType: SERVICE_TYPE[slug!],
  },
});
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  <SectionRenderer sections={entry.sections} />
</PageLayout>
