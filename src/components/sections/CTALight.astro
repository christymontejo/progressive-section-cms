---
import Button from "../ui/Button.astro";

interface Props {
  title: string;
  description: string;
  ctaText: string;
  ctaLink: string;
}

const { title, description, ctaText, ctaLink } = Astro.props;
---

<section class="py-16 md:py-24 bg-white fade-in-section">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center space-y-8">
      <!-- Title -->
      <h2 class="section-title text-primary">
        {title}
      </h2>

      <!-- Decorative divider -->
      <div class="flex items-center justify-center gap-4">
        <div class="h-px w-16 bg-primary-light"></div>
        <div class="w-3 h-3 rounded-full bg-primary-light"></div>
        <div class="h-px w-16 bg-primary-light"></div>
      </div>

      <!-- Description with HTML support -->
      <div
        class="section-description text-primary-dark"
        set:html={description}
      />

      <!-- CTA Button -->
      <div class="pt-4">
        <Button href={ctaLink} variant="primary" size="lg">
          {ctaText}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </Button>
      </div>
    </div>
  </div>
</section>
