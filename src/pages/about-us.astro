---
import PageLayout from "~/layouts/PageLayout.astro";
import SectionRenderer from "~/components/sections/SectionRenderer.astro";

import aboutDataRaw from "~/data/pages/main/about-us.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";
const aboutData = localizeData(aboutDataRaw);
const { sections } = aboutData;

const { metadata, extraSchemas } = buildPageMeta(aboutData);
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  <SectionRenderer sections={sections} />
</PageLayout>

<style is:global>
  @media (min-width: 1024px) {
    /* Target the 2nd section ContentWithImage image wrapper */
    section:nth-of-type(2) [data-image-sticky] {
      position: sticky !important;
      top: 6rem !important;
    }
  }
</style>
