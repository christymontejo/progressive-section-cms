---
import { Image } from "astro:assets";

interface DesignSkill {
  title: string;
  description?: string;
  image?: string;
  background?: string; // "primary-dark" | "primary-light" | "image"
  fit?: "cover" | "contain";
}

interface Props {
  title?: string;
  description?: string;
  skills: DesignSkill[];
}

const { title, description, skills = [] } = Astro.props;
---

<section class="py-12 md:py-20 bg-white fade-in-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      (title || description) && (
        <div class="max-w-3xl mb-20">
          {title && (
            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6 leading-tight">
              {title}
            </h2>
          )}
          {description && (
            <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
              {description}
            </p>
          )}
        </div>
      )
    }

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        skills.map((skill) => (
          <div class="group relative aspect-[4/3] rounded-2xl overflow-hidden cursor-pointer shadow-xl hover:shadow-2xl transition-all duration-700 ease-out transform hover:-translate-y-1">
            {/* Background Image - Always render */}
            <div class="absolute inset-0 w-full h-full z-0">
              <Image
                src={
                  skill.image ||
                  "https://images.unsplash.com/photo-1561070791-2526d30994b5?w=800&h=600&fit=crop"
                }
                alt={skill.title}
                width={800}
                height={600}
                class={`w-full h-full ${skill.fit === "contain" ? "object-contain bg-white" : "object-cover"} transition-transform duration-700 ease-out group-hover:scale-110`}
                loading="lazy"
              />
            </div>

            {/* Overlay - darker on hover with smooth transition and slight blur */}
            <div class="absolute inset-0 z-10 bg-slate-900/40 group-hover:bg-slate-900/80 group-hover:backdrop-blur-sm transition-all duration-700 ease-in-out" />

            {/* Content Container */}
            <div class="absolute inset-0 z-20 flex flex-col justify-end p-6 text-white">
              {/* Title - always visible at bottom with smooth slide */}
              <h3 class="text-xl md:text-2xl font-bold mb-2 transition-all duration-700 ease-out transform group-hover:translate-y-[-4px]">
                {skill.title}
              </h3>

              {/* Description - slides up smoothly on hover */}
              {skill.description && (
                <div class="overflow-hidden transition-all duration-700 ease-out max-h-0 group-hover:max-h-48 transform">
                  <p class="text-sm leading-relaxed opacity-0 group-hover:opacity-100 transition-all duration-700 delay-150 ease-out transform translate-y-2 group-hover:translate-y-0">
                    {skill.description}
                  </p>
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
