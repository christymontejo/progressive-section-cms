---
interface GalleryImage {
  src: string;
  alt: string;
  label?: string;
  link?: string;
  description?: string;
}

interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  image?: string;
  galleryImages?: GalleryImage[];
}

const {
  title,
  eyebrow,
  description,
  ctaText,
  ctaLink,
  secondaryCtaText,
  secondaryCtaLink,
  image,
  galleryImages = [],
} = Astro.props;
---

<section
  class="pb-12 md:pb-20 relative overflow-hidden -mt-20 pt-40 md:min-h-0 flex flex-col justify-center"
>
  <!-- White Background - extends behind navbar -->
  <div class="absolute inset-0 top-[-80px] bg-white -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 md:mb-12 relative">
    <!-- Content -->
    <div class="pb-6 sm:pb-8 md:pb-12">
      <div class="max-w-4xl text-center mx-auto">
        {
          eyebrow && (
            <div class="inline-block mb-4 px-4 py-2 bg-white/50 backdrop-blur-sm rounded-full border border-primary-light/30">
              <span class="text-xs sm:text-sm font-semibold text-primary uppercase tracking-wider">
                {eyebrow}
              </span>
            </div>
          )
        }

        {
          title && (
            <h1 class="text-4xl sm:text-5xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-4 sm:mb-6 leading-tight">
              {title}
            </h1>
          )
        }

        {
          description && (
            <p class="text-base sm:text-lg md:text-xl text-gray-600 mb-8 sm:mb-10 leading-relaxed max-w-2xl mx-auto">
              {description}
            </p>
          )
        }

        {
          (ctaText || secondaryCtaText) && (
            <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 justify-center">
              {ctaText && ctaLink && (
                <a
                  href={ctaLink}
                  class="cta-button inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 sm:py-4 bg-primary-dark text-white text-sm sm:text-base font-bold rounded-full hover:bg-primary-darker leading-tight text-center"
                >
                  <span>{ctaText}</span>
                  <svg
                    class="w-4 h-4 sm:w-5 sm:h-5 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </a>
              )}
              {secondaryCtaText && secondaryCtaLink && (
                <a
                  href={secondaryCtaLink}
                  class="inline-flex items-center justify-center gap-2 px-6 sm:px-8 py-3 sm:py-4 bg-white/50 backdrop-blur-sm text-primary text-sm sm:text-base font-bold rounded-full border-2 border-primary-light hover:border-primary hover:bg-white/70 transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105 hover:-translate-y-0.5 active:scale-100 active:translate-y-0"
                >
                  {secondaryCtaText}
                </a>
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>

  <!-- Sliding Image Gallery -->
  {
    galleryImages && galleryImages.length > 0 && (
      <div class="overflow-hidden relative hidden md:block">
        <div class="absolute left-0 top-0 bottom-0 w-48 md:w-64 lg:w-80 bg-gradient-to-r from-white via-white/80 to-transparent z-30 pointer-events-none" />
        <div class="absolute right-0 top-0 bottom-0 w-48 md:w-64 lg:w-80 bg-gradient-to-l from-white via-white/80 to-transparent z-30 pointer-events-none" />
        <div class="gallery-track">
          <div class="gallery-slide">
            {galleryImages.map((img) => (
              <div class="gallery-item">
                {img.link ? (
                  <a
                    href={img.link}
                    class="block relative h-48 sm:h-56 md:h-64 rounded-2xl overflow-hidden group shadow-xl hover:shadow-2xl transition-all duration-700 ease-out transform"
                  >
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 z-10 bg-slate-900/40 group-hover:bg-slate-900/80 group-hover:backdrop-blur-sm transition-all duration-700 ease-in-out" />
                    <div class="absolute inset-0 z-20 flex flex-col justify-end p-4 text-white">
                      {img.label && (
                        <p class="text-base md:text-lg font-bold mb-2 transition-all duration-700 ease-out transform group-hover:translate-y-[-4px]">
                          {img.label}
                        </p>
                      )}
                      {img.description && (
                        <div class="overflow-hidden transition-all duration-700 ease-out max-h-0 group-hover:max-h-48 transform">
                          <p class="text-xs md:text-sm leading-relaxed opacity-0 group-hover:opacity-100 transition-all duration-700 delay-150 ease-out transform translate-y-2 group-hover:translate-y-0">
                            {img.description}
                          </p>
                        </div>
                      )}
                    </div>
                  </a>
                ) : (
                  <div class="relative h-48 sm:h-56 md:h-64 rounded-2xl overflow-hidden group shadow-xl">
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 z-10 bg-slate-900/40" />
                    <div class="absolute inset-0 z-20 flex flex-col justify-end p-4 text-white">
                      {img.label && (
                        <p class="text-base md:text-lg font-bold">
                          {img.label}
                        </p>
                      )}
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
          <div class="gallery-slide" aria-hidden="true">
            {galleryImages.map((img) => (
              <div class="gallery-item">
                {img.link ? (
                  <a
                    href={img.link}
                    class="block relative h-48 sm:h-56 md:h-64 rounded-2xl overflow-hidden group shadow-xl hover:shadow-2xl transition-all duration-700 ease-out transform hover:-translate-y-1"
                  >
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 z-10 bg-slate-900/40 group-hover:bg-slate-900/80 group-hover:backdrop-blur-sm transition-all duration-700 ease-in-out" />
                    <div class="absolute inset-0 z-20 flex flex-col justify-end p-4 text-white">
                      {img.label && (
                        <p class="text-base md:text-lg font-bold mb-2 transition-all duration-700 ease-out transform group-hover:translate-y-[-4px]">
                          {img.label}
                        </p>
                      )}
                      {img.description && (
                        <div class="overflow-hidden transition-all duration-700 ease-out max-h-0 group-hover:max-h-48 transform">
                          <p class="text-xs md:text-sm leading-relaxed opacity-0 group-hover:opacity-100 transition-all duration-700 delay-150 ease-out transform translate-y-2 group-hover:translate-y-0">
                            {img.description}
                          </p>
                        </div>
                      )}
                    </div>
                  </a>
                ) : (
                  <div class="relative h-48 sm:h-56 md:h-64 rounded-2xl overflow-hidden group shadow-xl">
                    <img
                      src={img.src}
                      alt={img.alt}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 z-10 bg-slate-900/40" />
                    <div class="absolute inset-0 z-20 flex flex-col justify-end p-4 text-white">
                      {img.label && (
                        <p class="text-base md:text-lg font-bold">
                          {img.label}
                        </p>
                      )}
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    )
  }
</section>

<style>
  .cta-button {
    transform: scale(1);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
                background-color 0.25s ease, 
                box-shadow 0.25s ease,
                border-color 0.25s ease;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    -webkit-transform: translateZ(0) scale(1);
    transform: translateZ(0) scale(1);
  }

  .cta-button::before {
    display: none !important;
  }

  .cta-button:hover {
    -webkit-transform: translateZ(0) scale(1.05);
    transform: translateZ(0) scale(1.05);
  }

  .cta-button:active {
    -webkit-transform: translateZ(0) scale(1);
    transform: translateZ(0) scale(1);
  }

  .gallery-track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: scroll 60s linear infinite;
  }

  .gallery-track:hover {
    animation-play-state: paused;
  }

  .gallery-slide {
    display: flex;
    flex-shrink: 0;
    gap: 1rem;
    padding-right: 1rem;
  }

  .gallery-item {
    flex: 0 0 220px;
  }

  @media (min-width: 640px) {
    .gallery-slide {
      gap: 1.25rem;
      padding-right: 1.25rem;
    }
    .gallery-item {
      flex: 0 0 240px;
    }
  }

  @media (min-width: 768px) {
    .gallery-slide {
      gap: 1.5rem;
      padding-right: 1.5rem;
    }
    .gallery-item {
      flex: 0 0 260px;
    }
  }

  @media (min-width: 1024px) {
    .gallery-item {
      flex: 0 0 280px;
    }
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
