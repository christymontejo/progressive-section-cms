---
import Button from "../ui/Button.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  image: string;
  ctaText?: string;
  ctaLink?: string;
  eyebrow?: string;
  keyPoints: string[];
  background?: "white" | "primary" | "light";
}

const {
  title,
  description,
  image,
  ctaText,
  ctaLink,
  eyebrow,
  keyPoints,
  background = "white",
} = Astro.props;

const bgClasses = {
  white: "bg-white",
  light: "bg-neutral",
  primary: "bg-primary",
};

const textColorClasses = {
  white: "text-primary",
  light: "text-primary",
  primary: "text-white",
};

const descriptionColorClasses = {
  white: "text-primary-dark",
  light: "text-primary-dark",
  primary: "text-neutral",
};
---

<section class={`py-16 md:py-24 ${bgClasses[background]} fade-in-section`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Content -->
    <div class="max-w-3xl mb-12">
      {
        eyebrow && (
          <div
            class={`inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4 ${background === "primary" ? "bg-white/10 border border-white/20" : "bg-primary/5 border border-primary-light/30"}`}
          >
            <span
              class={`w-2 h-2 rounded-full ${background === "primary" ? "bg-white" : "bg-primary-light"}`}
            />
            <span
              class={`section-eyebrow ${background === "primary" ? "text-white" : "text-primary"}`}
            >
              {eyebrow}
            </span>
          </div>
        )
      }

      <h2 class={`section-title mb-6 ${textColorClasses[background]}`}>
        {title}
      </h2>

      <div class={`section-description ${descriptionColorClasses[background]}`} set:html={description} />
    </div>

    <!-- Image + Key Points Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Large Image Card -->
      <div class="lg:col-span-2">
        <div
          class="relative h-full min-h-[400px] rounded-2xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.3)] group"
        >
          <picture>
            <source 
              media="(max-width: 768px)" 
              srcset={image.replace('.avif', '-mobile.avif')}
              type="image/avif"
            />
            <img
              src={image}
              alt={title}
              width="800"
              height="600"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </picture>

          <!-- Gradient overlay -->
          <div
            class={`absolute inset-0 ${background === "primary" ? "bg-gradient-to-t from-white/10 to-transparent" : "bg-gradient-to-t from-primary/10 to-transparent"}`}
          >
          </div>
        </div>
      </div>

      <!-- Key Points Cards -->
      <div class="space-y-4">
        {
          keyPoints.map((point, index) => (
            <div
              class={`p-6 rounded-xl border-2 transition-all duration-300 hover:scale-105 ${
                background === "primary"
                  ? "bg-white/5 border-white/20 hover:bg-white/10 hover:border-white/40"
                  : "bg-white border-primary-light/30 hover:border-primary-light shadow-lg hover:shadow-xl"
              }`}
            >
              <div class="flex items-start gap-4">
                <div
                  class={`flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center font-bold ${
                    background === "primary"
                      ? "bg-white text-primary"
                      : "bg-primary text-white"
                  }`}
                >
                  <Icon name="tabler:check" class="w-6 h-6" />
                </div>
                <p
                  class={`text-base font-semibold pt-2 ${
                    background === "primary" ? "text-white" : "text-primary"
                  }`}
                >
                  {point}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- CTA Button -->
    {
      ctaText && ctaLink && (
        <div class="mt-12 flex justify-center">
          <Button
            href={ctaLink}
            variant={background === "primary" ? "secondary" : "primary"}
            size="lg"
          >
            {ctaText}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </Button>
        </div>
      )
    }
  </div>
</section>
