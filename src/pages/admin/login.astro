---
import { Font } from "astro:assets";
import { siteConfig } from "~/config/site";
import { isProductionCms } from "~/lib/cms";
import { sanitizeRedirect } from "~/lib/adminSession";
import Button from "~/components/ui/Button.astro";
import "~/styles/global.css";

export const prerender = false;

const isProd = isProductionCms();
const hasError = Astro.url.searchParams.get("error") === "1";
// Sanitized here too (not just before the redirect happens on submit) so
// the value we embed in the hidden field / append to the GitHub login link
// can never itself be an open-redirect payload.
const redirectTarget = sanitizeRedirect(Astro.url.searchParams.get("redirect"));
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Login | {siteConfig.business.name}</title>
    <Font cssVariable="--font-poppins" preload />
  </head>
  <body class="antialiased text-gray-900 bg-primary-dark min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-2xl p-8 sm:p-10 text-center space-y-6">
        <img
          src={siteConfig.logo.src}
          alt={siteConfig.logo.alt}
          class="h-10 mx-auto"
        />

        <div class="space-y-2">
          <p class="section-eyebrow text-primary-light">Admin</p>
          <h1 class="text-2xl font-bold text-primary-dark">Sign In</h1>
          <p class="text-gray-600">
            Sign in to manage {siteConfig.business.name}'s content.
          </p>
        </div>

        {
          hasError && (
            <p class="text-sm font-semibold text-red-600 bg-red-50 border border-red-200 rounded-lg py-2 px-3">
              Incorrect password. Please try again.
            </p>
          )
        }

        {
          isProd ? (
            <Button
              href={`/api/keystatic/github/login`}
              variant="primary"
              size="lg"
              class="w-full"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="w-5 h-5"
                fill="currentColor"
              >
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.57.1.78-.25.78-.55 0-.27-.01-1.15-.02-2.09-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a10.9 10.9 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.8 1.19 1.83 1.19 3.09 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.07.78 2.15 0 1.55-.01 2.8-.01 3.18 0 .3.2.66.79.55A10.52 10.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
              </svg>
              Login with GitHub
            </Button>
          ) : (
            <form method="POST" action="/api/admin-login" class="space-y-4 text-left">
              <input type="hidden" name="redirect" value={redirectTarget} />
              <div>
                <label for="password" class="block text-sm font-bold text-primary-dark mb-1">
                  Password
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  autofocus
                  class="w-full rounded-lg border-2 border-gray-200 px-4 py-3 text-base focus:border-primary-light focus:outline-none transition-colors"
                />
              </div>
              <Button type="submit" variant="primary" size="lg" class="w-full">
                Login
              </Button>
            </form>
          )
        }

        <p class="text-xs text-gray-400 pt-2">
          {isProd ? "Access is managed via GitHub repository permissions." : "Local development mode."}
        </p>
      </div>
    </div>
  </body>
</html>
