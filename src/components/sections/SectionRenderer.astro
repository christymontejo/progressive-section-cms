---
/**
 * SectionRenderer
 *
 * Renders the new discriminant/value section format used by all page and
 * location JSON files, e.g.:
 *   { "discriminant": "hero", "value": { "title": ..., "buttonText": ... } }
 *
 * Each discriminant is mapped to the closest existing section component and the
 * new field names are normalized to that component's props (buttonText/buttonHref
 * -> ctaText/ctaLink, subtitle -> description, badge -> eyebrow, href -> url, etc).
 */
import Hero from "~/components/sections/Hero.astro";
import HeroHome from "~/components/sections/HeroHome.astro";
import ContentWithImage from "~/components/sections/ContentWithImage.astro";
import ContentWithKeypoints from "~/components/sections/ContentWithKeypoints.astro";
import BoostVisibility from "~/components/sections/BoostVisibility.astro";
import FeaturesSection from "~/components/sections/FeaturesSection.astro";
import FeaturesWithImage from "~/components/sections/FeaturesWithImage.astro";
import ServicesGrid from "~/components/sections/ServicesGrid.astro";
import CallToAction from "~/components/sections/CallToAction.astro";
import CTALight from "~/components/sections/CTALight.astro";
import FAQs from "~/components/sections/FAQs.astro";
import MapSection from "~/components/sections/MapSection.astro";
import FormSection from "~/components/sections/FormSection.astro";
import NetworksSection from "~/components/sections/NetworksSection.astro";
import { resolveCardHref, resolveCardImage, resolveCardTitle } from "~/lib/relatedLinks";

interface RawSection {
  discriminant?: string;
  // legacy flat shape support
  section?: string;
  value?: Record<string, any>;
  order?: number;
  [key: string]: any;
}

interface Props {
  sections?: RawSection[];
  /** Locations to remove from `locations` sections (used on location pages). */
  filterLocation?: string;
}

const { sections = [], filterLocation } = Astro.props;

// The new JSON stores icon names without the icon-set prefix (e.g. "rocket",
// "mappin"). astro-icon needs a set prefix, so add "tabler:" and remap the few
// names that don't match a real tabler icon.
const ICON_REMAP: Record<string, string> = {
  circledot: "circle-dot",
  dollar: "currency-dollar",
  google: "brand-google",
  mappin: "map-pin",
  megaphone: "speakerphone",
  monitor: "device-desktop",
  share2: "share",
  trending: "trending-up",
  tv: "device-tv",
  zap: "bolt",
};
const normalizeIcon = (icon?: string): string | undefined => {
  if (!icon) return icon;
  if (icon.includes(":")) return icon; // already prefixed
  return `tabler:${ICON_REMAP[icon] || icon}`;
};
// Map a features/cards array, normalizing each item's `icon`.
const withIcons = (items: any[] = []) =>
  items.map((it) =>
    it && typeof it === "object" && "icon" in it
      ? { ...it, icon: normalizeIcon(it.icon) }
      : it
  );

// Accept either the new { discriminant, value } shape or a legacy flat object.
interface NormalizedSection {
  type: string;
  v: Record<string, any>;
  order: number;
}

const normalized: NormalizedSection[] = sections
  .map((s: RawSection) => ({
    type: (s.discriminant || s.section || "").toString(),
    v: (s.value || s) as Record<string, any>,
    order: s.order ?? s.value?.order ?? 0,
  }))
  .sort((a: NormalizedSection, b: NormalizedSection) => (a.order || 0) - (b.order || 0));

// Normalize an allowed background value or fall back to undefined.
const bg = (v: any): any => v || undefined;

// Normalize a locations array: map { name, href } -> { name, url }.
const mapLocations = (locs: any[] = []) =>
  locs
    .map((loc) =>
      typeof loc === "string" ? loc : { name: loc.name, url: loc.href || loc.url }
    )
    .filter((loc) => {
      if (!filterLocation) return true;
      const n = typeof loc === "string" ? loc : loc?.name;
      return n && n.toLowerCase() !== filterLocation.toLowerCase();
    });
---

{
  normalized.map(({ type, v }) => {
    switch (type) {
      case "hero":
      case "Hero":
        return (
          <Hero
            tagline={v.badge || v.eyebrow}
            title={v.title}
            subtitle={v.subtitle || v.description}
            image={v.image}
            imageAlt={v.imageAlt}
            actions={
              (v.buttonText || v.ctaText) && (v.buttonHref || v.ctaLink)
                ? [
                    {
                      text: v.buttonText || v.ctaText,
                      href: v.buttonHref || v.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );

      case "heroHome":
      case "HeroHome":
        return (
          <HeroHome
            eyebrow={v.badge || v.eyebrow}
            title={v.title}
            description={v.subtitle || v.description}
            ctaText={v.buttonText || v.ctaText}
            ctaLink={v.buttonHref || v.ctaLink}
            secondaryCtaText={v.secondaryCtaText}
            secondaryCtaLink={v.secondaryCtaLink}
            image={v.image}
            galleryImages={(v.cards || []).map((c: any) => ({
              src: resolveCardImage(c),
              alt: resolveCardTitle(c),
              label: resolveCardTitle(c),
              description: c.description,
              link: resolveCardHref(c),
            }))}
          />
        );

      case "ContentWithKeypoints":
        return (
          <ContentWithKeypoints
            title={v.title}
            eyebrow={v.badge || v.eyebrow}
            description={v.description}
            image={v.image}
            imageAlt={v.imageAlt}
            ctaText={v.buttonText || v.ctaText}
            ctaLink={v.buttonHref || v.ctaLink}
            keyPoints={v.keyPoints || (v.features || []).map((f: any) => f.text || f.title)}
            background={bg(v.background)}
          />
        );

      case "content":
      case "ContentWithImage": {
        const featureList = Array.isArray(v.features) ? v.features : [];

        // `simple` variant: two-column (image + icon feature cards + CTA).
        // Each feature's `text` is "Title. Description." — split on the first
        // period so the card shows a bold title and its supporting line.
        if (v.variant === "simple" && featureList.length > 0) {
          const cards = withIcons(featureList).map((f: any) => {
            const raw = f.text || f.title || "";
            const dot = raw.indexOf(". ");
            const title = dot > -1 ? raw.slice(0, dot) : raw;
            const description = dot > -1 ? raw.slice(dot + 2) : f.description || "";
            return { icon: f.icon, title, description, link: f.link || f.href };
          });
          return (
            <BoostVisibility
              title={v.title}
              description={v.description}
              image={v.image}
              imageAlt={v.imageAlt}
              ctaText={v.buttonText || v.ctaText}
              ctaLink={v.buttonHref || v.ctaLink}
              features={cards}
              background={bg(v.background)}
            />
          );
        }

        // Otherwise, a feature/keypoint checklist renders as the image +
        // keypoints layout; a bare block uses the plain image + text layout.
        const keyPoints =
          v.keyPoints ||
          featureList.map((f: any) => f.text || f.title).filter(Boolean);
        if (keyPoints.length > 0) {
          return (
            <ContentWithKeypoints
              title={v.title}
              eyebrow={v.badge || v.eyebrow}
              description={v.description}
              image={v.image}
              imageAlt={v.imageAlt}
              ctaText={v.buttonText || v.ctaText}
              ctaLink={v.buttonHref || v.ctaLink}
              keyPoints={keyPoints}
              background={bg(v.background)}
            />
          );
        }
        return (
          <ContentWithImage
            title={v.title}
            eyebrow={v.badge || v.eyebrow}
            description={v.description}
            ctaText={v.buttonText || v.ctaText}
            ctaLink={v.buttonHref || v.ctaLink}
            image={v.image}
            imageAlt={v.imageAlt}
            imagePosition={v.imagePosition}
            background={bg(v.background)}
          />
        );
      }

      case "featuresWithButton":
      case "ServicesGrid": {
        // Dark, centered heading with a grid of linked service cards + CTA.
        if (!v.features || v.features.length === 0) return null;
        return (
          <ServicesGrid
            title={v.title}
            description={v.description}
            ctaText={v.buttonText || v.ctaText}
            ctaLink={v.buttonHref || v.ctaLink}
            cards={withIcons(v.features).map((f: any) => ({
              title: f.title,
              description: f.description,
              icon: f.icon,
              link: f.href || f.link,
            }))}
          />
        );
      }

      case "features":
      case "FeaturesSection": {
        if (!v.features || v.features.length === 0) return null;
        return (
          <FeaturesSection
            eyebrow={v.badge || v.eyebrow}
            title={v.title}
            description={v.description}
            features={withIcons(v.features)}
            ctaText={v.buttonText || v.ctaText}
            ctaLink={v.buttonHref || v.ctaLink}
            background={bg(v.background)}
          />
        );
      }

      case "valueCards":
      case "FeaturesWithImage": {
        const cards = v.cards || v.features || [];
        if (cards.length === 0) return null;
        // The "overlay" variant (image-overlay cards, e.g. "What Sets Us Apart")
        // is a carousel; the "cards" variant is a static process-step grid.
        const isCarousel =
          v.isCarousel ?? v.variant === "overlay";
        return (
          <FeaturesWithImage
            eyebrow={v.badge || v.eyebrow}
            title={v.title}
            description={v.description}
            cards={withIcons(cards)}
            ctaText={v.buttonText || v.ctaText}
            ctaLink={v.buttonHref || v.ctaLink}
            background={bg(v.background)}
            isCarousel={isCarousel}
            itemsPerSlide={v.itemsPerSlide ?? 2}
            carouselAutoplay={v.carouselAutoplay}
            carouselAutoplayDelay={v.carouselAutoplayDelay}
          />
        );
      }

      case "faq":
      case "faqs":
      case "FAQs": {
        if (!v.faqs || v.faqs.length === 0) return null;
        return (
          <FAQs
            title={v.title}
            description={v.description}
            faqs={v.faqs}
            background={bg(v.background)}
          />
        );
      }

      case "locations":
      case "Map":
      case "MapSection":
        return (
          <MapSection
            title={v.title}
            eyebrow={v.badge || v.eyebrow}
            description={v.description}
            locations={mapLocations(v.locations)}
            mapUrl={v.mapUrl}
            viewMode={v.variant === "full" ? "full" : v.viewMode}
            background={bg(v.background)}
          />
        );

      case "CTALight":
        return (
          <CTALight
            title={v.title}
            description={v.subtitle || v.description}
            ctaText={v.buttonText || v.ctaText || "Get in Touch"}
            ctaLink={v.buttonHref || v.ctaLink || "/contact-us"}
          />
        );

      case "cta":
      case "CTA":
      case "CallToAction": {
        // The "card" variant is the light, centered CTA (dark text on a light
        // background with a divider); other variants use the dark card CTA.
        if (v.variant === "card") {
          return (
            <CTALight
              title={v.title}
              description={v.subtitle || v.description}
              ctaText={v.buttonText || v.ctaText || "Get in Touch"}
              ctaLink={v.buttonHref || v.ctaLink || "/contact-us"}
            />
          );
        }
        return (
          <CallToAction
            title={v.title}
            subtitle={v.subtitle || v.description}
            image={v.image}
            imageAlt={v.imageAlt}
            actions={
              (v.buttonText || v.ctaText) && (v.buttonHref || v.ctaLink)
                ? [
                    {
                      text: v.buttonText || v.ctaText,
                      href: v.buttonHref || v.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );
      }

      case "contact":
      case "FormSection": {
        // The new `contact` shape carries a contactInfo *object*; convert it to
        // the contactInfo array FormSection expects.
        const ci = v.contactInfo || {};
        const contactInfo = Array.isArray(ci)
          ? ci
          : [
              ci.phoneFormatted && {
                icon: "tabler:phone",
                label: "Phone",
                value: ci.phoneFormatted,
                link: ci.phone ? `tel:${ci.phone}` : undefined,
              },
              ci.email && {
                icon: "tabler:mail",
                label: "Email",
                value: ci.email,
                link: `mailto:${ci.email}`,
              },
              ci.location && {
                icon: "tabler:map-pin",
                label: "Location",
                value: ci.location,
              },
            ].filter(Boolean);
        return (
          <FormSection
            title={v.title}
            subtitle={v.secondaryDescription}
            description={v.description}
            fields={v.formFields || []}
            submitText={v.submitText}
            submitAction={v.submitAction}
            background={bg(v.background)}
            contactInfo={contactInfo}
            image={v.image}
          />
        );
      }

      case "network":
      case "networks":
      case "NetworksSection":
        return (
          <NetworksSection
            title={v.title}
            description={v.description}
            networks={v.networks}
          />
        );

      default:
        return null;
    }
  })
}
