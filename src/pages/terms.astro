---
import PageLayout from "~/layouts/PageLayout.astro";
import SectionRenderer from "~/components/sections/SectionRenderer.astro";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";

import termsDataRaw from "~/data/pages/legal/terms.json";

const termsData = localizeData(termsDataRaw);
const { sections, legalSections = [] } = termsData;
const { metadata, extraSchemas } = buildPageMeta(termsData);
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  <SectionRenderer sections={sections} />

  {
    legalSections.length > 0 && (
      <section class="py-16 md:py-20 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="prose prose-lg max-w-none">
            {legalSections.map((s: { title: string; content: string }) => (
              <>
                <h2 class="text-2xl font-bold text-gray-900 mt-8 mb-4">
                  {s.title}
                </h2>
                <p class="text-gray-600 mb-6" set:html={s.content} />
              </>
            ))}
          </div>
        </div>
      </section>
    )
  }
</PageLayout>
