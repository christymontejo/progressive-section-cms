---
import { Font } from "astro:assets";
import { siteConfig } from "~/config/site";
import Button from "~/components/ui/Button.astro";
import "~/styles/global.css";

export const prerender = false;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Access Denied | {siteConfig.business.name}</title>
    <Font cssVariable="--font-poppins" preload />
  </head>
  <body class="antialiased text-gray-900 bg-primary-dark min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-2xl p-8 sm:p-10 text-center space-y-6">
        <img
          src={siteConfig.logo.src}
          alt={siteConfig.logo.alt}
          class="h-10 mx-auto"
        />

        <div class="space-y-2">
          <h1 class="text-2xl font-bold text-primary-dark">Access Denied</h1>
          <p class="text-gray-600">
            You signed in with GitHub successfully, but that account isn't a
            collaborator on {siteConfig.business.name}'s content repository,
            so it can't be used to manage this site.
          </p>
        </div>

        <Button href="/api/admin-logout" variant="primary" size="lg" class="w-full">
          Try a Different GitHub Account
        </Button>
        <Button href="/" variant="outline" size="md" class="w-full">
          Return to Site
        </Button>
      </div>
    </div>
  </body>
</html>
