---
import { Icon } from "astro-icon/components";

interface Card {
  title: string;
  description: string;
  icon: string;
  link: string;
}

interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaLink?: string;
  cards?: Card[];
}

const { title, description, ctaText, ctaLink, cards = [] } = Astro.props;
---

<section class="services-grid-section fade-in-section">
  <div class="container">
    <!-- Header -->
    {
      (title || description) && (
        <div class="section-header">
          {title && <h2 class="section-title">{title}</h2>}
          {description && <p class="section-description" set:html={description} />}
        </div>
      )
    }

    <!-- Service Grid -->
    <div class="services-grid stagger">
      {
        cards.map((card) =>
          card.link ? (
            <a href={card.link} class="service-card">
              <div class="card-inner">
                <div class="icon-wrapper">
                  <div class="icon-bg" />
                  <Icon name={card.icon} class="service-icon" />
                </div>
                <h3 class="card-title">{card.title}</h3>
                <p class="card-description">{card.description}</p>
                <div class="card-arrow">
                  <Icon name="tabler:arrow-right" />
                </div>
              </div>
            </a>
          ) : (
            <div class="service-card">
              <div class="card-inner">
                <div class="icon-wrapper">
                  <div class="icon-bg" />
                  <Icon name={card.icon} class="service-icon" />
                </div>
                <h3 class="card-title">{card.title}</h3>
                <p class="card-description">{card.description}</p>
                <div class="card-arrow">
                  <Icon name="tabler:arrow-right" />
                </div>
              </div>
            </div>
          )
        )
      }
    </div>

    <!-- CTA Button -->
    {
      ctaText && ctaLink && (
        <div class="cta-wrapper">
          <a href={ctaLink} class="cta-button">
            {ctaText}
            <Icon name="tabler:arrow-right" class="cta-icon" />
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .services-grid-section {
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      var(--color-primary-darker) 50%,
      var(--color-primary) 100%
    );
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .services-grid-section.fade-in-section {
    opacity: 1;
  }

  .services-grid-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
        circle at 20% 30%,
        rgba(161, 194, 189, 0.08) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 70%,
        rgba(112, 137, 147, 0.06) 0%,
        transparent 50%
      );
    pointer-events: none;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  /* Section Header */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    animation: fadeInUp 0.8s ease-out;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .section-description {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 900px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .section-description :global(a) {
    color: var(--color-primary-light);
    text-decoration: underline;
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Service Card */
  .service-card {
    position: relative;
    text-decoration: none;
    display: block;
    height: 100%;
    animation: fadeInUp 0.8s ease-out backwards;
  }

  .service-card:nth-child(1) {
    animation-delay: 0.1s;
  }
  .service-card:nth-child(2) {
    animation-delay: 0.2s;
  }
  .service-card:nth-child(3) {
    animation-delay: 0.3s;
  }
  .service-card:nth-child(4) {
    animation-delay: 0.4s;
  }

  .card-inner {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.25rem;
    padding: 2rem 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-inner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(161, 194, 189, 0.15) 0%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .service-card:hover .card-inner {
    transform: translateY(-8px);
    border-color: var(--color-primary-light);
    background: rgba(255, 255, 255, 0.08);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 0 1px var(--color-primary-light),
      inset 0 0 60px rgba(161, 194, 189, 0.08);
  }

  .service-card:hover .card-inner::before {
    opacity: 1;
  }

  /* Icon Wrapper */
  .icon-wrapper {
    position: relative;
    width: 70px;
    height: 70px;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      var(--color-primary-light) 0%,
      var(--color-primary-dark) 100%
    );
    border-radius: 1rem;
    opacity: 0.2;
    transition: all 0.4s ease;
  }

  .service-card:hover .icon-bg {
    opacity: 0.35;
    transform: rotate(10deg) scale(1.1);
  }

  .service-icon {
    width: 36px;
    height: 36px;
    color: var(--color-primary-light);
    position: relative;
    z-index: 1;
    transition: all 0.4s ease;
  }

  .service-card:hover .service-icon {
    transform: scale(1.1);
    color: var(--color-neutral);
  }

  /* Card Content */
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.75rem;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .service-card:hover .card-title {
    color: var(--color-primary-light);
  }

  .card-description {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 1rem;
  }

  /* Card Arrow */
  .card-arrow {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-top: auto;
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .card-arrow :global(svg) {
    width: 20px;
    height: 20px;
    color: var(--color-primary-light);
    transition: transform 0.3s ease;
  }

  .service-card:hover .card-arrow {
    opacity: 1;
  }

  .service-card:hover .card-arrow :global(svg) {
    transform: translateX(5px);
  }

  /* CTA Wrapper */
  .cta-wrapper {
    text-align: center;
    margin-top: 3rem;
    animation: fadeInUp 0.8s ease-out 0.5s backwards;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: #ffffff;
    color: var(--color-primary);
    font-size: 1.125rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 9999px;
    transition: all 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .cta-button:hover {
    background: var(--color-neutral);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
    transform: translateY(-2px);
  }

  .cta-icon {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .cta-button:hover .cta-icon {
    transform: translateX(5px);
  }

  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .services-grid-section {
      padding: 4rem 0;
    }

    .section-header {
      margin-bottom: 2.5rem;
    }

    .services-grid {
      gap: 1.5rem;
    }

    .card-inner {
      padding: 1.75rem 1.25rem;
    }

    .cta-button {
      padding: 0.875rem 2rem;
      font-size: 1rem;
    }
  }
</style>
