---
import PageLayout from "~/layouts/PageLayout.astro";
import Hero from "~/components/sections/Hero.astro";
import HeroHome from "~/components/sections/HeroHome.astro";
import ServicesGrid from "~/components/sections/ServicesGrid.astro";
import ContentWithKeypoints from "~/components/sections/ContentWithKeypoints.astro";
import ContentWithImage from "~/components/sections/ContentWithImage.astro";
import BoostVisibility from "~/components/sections/BoostVisibility.astro";
import CallToAction from "~/components/sections/CallToAction.astro";
import FAQs from "~/components/sections/FAQs.astro";
import MapSection from "~/components/sections/MapSection.astro";
import PopupModal from "~/components/ui/PopupModal.astro";
import FloatingCTAButton from "~/components/ui/FloatingCTAButton.astro";

// Get homepage content from JSON data
import homeDataRaw from "~/data/pages/home.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";
import { getSolutionsData, getIndoorBillboardsData } from "~/data/collections";

const homeData = localizeData(homeDataRaw);
const { sections } = homeData;
const { metadata, extraSchemas } = buildPageMeta(homeData);

// Get all solutions and indoor-billboards for the gallery
const solutions = getSolutionsData();
const indoorBillboards = getIndoorBillboardsData();

// Combine and map to gallery images
const galleryImages = [
  ...solutions.map((solution) => ({
    src:
      solution.data.thumbnail ||
      solution.data.image ||
      "https://via.placeholder.com/400x300",
    alt: solution.data.title,
    label: solution.data.title,
    description: solution.data.description,
    link: `/solutions/${solution.slug}`,
  })),
  ...indoorBillboards.map((billboard) => ({
    src:
      billboard.data.thumbnail ||
      billboard.data.image ||
      "https://via.placeholder.com/400x300",
    alt: billboard.data.title,
    label: billboard.data.title,
    description: billboard.data.description,
    link: `/indoor-billboards/${billboard.slug}`,
  })),
].sort((a, b) => a.label.localeCompare(b.label));

// Helper to find section by name
const getSection = (name: string) => sections.find((s: any) => s.section === name);
// Helper to find section by name and order
const getSectionByOrder = (name: string, order: number) =>
  sections.find((s: any) => s.section === name && s.order === order);

const heroSection = getSection("Hero");
const heroHomeSection = getSection("HeroHome");
const servicesGridSection = getSection("ServicesGrid");
const venueNetworkSection = getSectionByOrder("ContentWithKeypoints", 3);
const boostVisibilitySection = getSection("BoostVisibility");
const whyChooseUsSection = getSectionByOrder("ContentWithImage", 5);
const ctaBannerSection = getSection("CTABanner");
const faqsSection = getSection("FAQs");
const mapSection = getSection("Map");
const finalCTASection = getSection("FinalCTA");
---

<PageLayout metadata={metadata} showGlobalCTA={false} extraSchemas={extraSchemas}>
  {
    heroHomeSection && (
      <HeroHome
        eyebrow={heroHomeSection.eyebrow}
        title={heroHomeSection.title}
        description={heroHomeSection.description}
        ctaText={heroHomeSection.ctaText}
        ctaLink={heroHomeSection.ctaLink}
        secondaryCtaText={heroHomeSection.secondaryCtaText}
        secondaryCtaLink={heroHomeSection.secondaryCtaLink}
        image={heroHomeSection.image}
        galleryImages={galleryImages}
      />
    )
  }

  {
    heroSection && !heroHomeSection && (
      <Hero
        tagline={heroSection.eyebrow}
        title={heroSection.title}
        subtitle={heroSection.description}
        image={heroSection.image}
        actions={[
          {
            text: heroSection.ctaText || "Get Started",
            href: heroSection.ctaLink || "/contact",
            variant: "primary",
          },
        ]}
      />
    )
  }

  {
    servicesGridSection && servicesGridSection.cards && (
      <ServicesGrid
        title={servicesGridSection.title}
        description={servicesGridSection.description}
        ctaText={servicesGridSection.ctaText}
        ctaLink={servicesGridSection.ctaLink}
        cards={servicesGridSection.cards as { title: string; description: string; icon: string; link: string }[]}
      />
    )
  }

  {
    venueNetworkSection && (
      <ContentWithKeypoints
        title={venueNetworkSection.title}
        description={venueNetworkSection.description}
        ctaText={venueNetworkSection.ctaText}
        ctaLink={venueNetworkSection.ctaLink}
        keyPoints={venueNetworkSection.keyPoints}
        image={venueNetworkSection.image}
      />
    )
  }

  {
    boostVisibilitySection && boostVisibilitySection.features && (
      <BoostVisibility
        title={boostVisibilitySection.title!}
        description={boostVisibilitySection.description!}
        image={boostVisibilitySection.image!}
        ctaText={boostVisibilitySection.ctaText!}
        ctaLink={boostVisibilitySection.ctaLink!}
        features={boostVisibilitySection.features as { title: string; description: string; icon: string; link?: string }[]}
      />
    )
  }

  {
    whyChooseUsSection && whyChooseUsSection.section === "ContentWithImage" && (
      <ContentWithImage
        eyebrow={whyChooseUsSection.eyebrow}
        title={whyChooseUsSection.title}
        description={whyChooseUsSection.description}
        ctaText={whyChooseUsSection.ctaText}
        ctaLink={whyChooseUsSection.ctaLink}
        image={whyChooseUsSection.image}
        background={whyChooseUsSection.background as "white" | "primary" | "primary-dark" | "light" | "gray"}
        imagePosition={whyChooseUsSection.imagePosition}
      />
    )
  }
  {
    whyChooseUsSection &&
      whyChooseUsSection.section === "ContentWithKeypoints" && (
        <ContentWithKeypoints
          eyebrow={whyChooseUsSection.eyebrow}
          title={whyChooseUsSection.title}
          description={whyChooseUsSection.description}
          ctaText={whyChooseUsSection.ctaText}
          ctaLink={whyChooseUsSection.ctaLink}
          keyPoints={whyChooseUsSection.keyPoints}
          image={whyChooseUsSection.image}
        />
      )
  }

  {
    ctaBannerSection && (
      <CallToAction
        title={ctaBannerSection.title}
        subtitle={ctaBannerSection.description}
        actions={[
          {
            text: ctaBannerSection.ctaText || "Get Started",
            href: ctaBannerSection.ctaLink || "/contact",
            variant: "primary",
          },
        ]}
      />
    )
  }

  {
    faqsSection && faqsSection.faqs && (
      <FAQs title={faqsSection.title} faqs={faqsSection.faqs as { question: string; answer: string }[]} />
    )
  }

  {
    mapSection && (
      <MapSection
        title={mapSection.title}
        description={mapSection.description}
        locations={mapSection.locations as (string | { name: string; url: string })[]}
        mapUrl={mapSection.mapUrl}
        viewMode={mapSection.viewMode}
      />
    )
  }

  {
    finalCTASection && (
      <CallToAction
        title={finalCTASection.title}
        subtitle={finalCTASection.description}
        actions={[
          {
            text: finalCTASection.ctaText || "Get Started",
            href: finalCTASection.ctaLink || "/contact",
            variant: "primary",
          },
        ]}
      />
    )
  }

  <!-- Floating CTA Button -->
  <FloatingCTAButton id="free-scan-button" text="Ask for a Free Scan" />

  <!-- Popup Modal -->
  <PopupModal triggerId="free-scan-button" delay={5000} showOnce={true} />
</PageLayout>
