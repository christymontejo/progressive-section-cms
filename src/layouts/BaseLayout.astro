---
import type { MetaData } from "~/types";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
import Header from "~/components/ui/Header.astro";
import Footer from "~/components/ui/Footer.astro";
import CallToAction from "~/components/sections/CallToAction.astro";
import ScrollAnimations from "~/components/ui/ScrollAnimations.astro";
import { siteConfig, localizeMetadata } from "~/config/site";
import {
  organizationSchema,
  brandOrganizationSchema,
  websiteSchema,
  webPageSchema,
  breadcrumbSchema,
} from "~/lib/schemas";
import "~/styles/global.css";

export interface Props {
  metadata?: MetaData;
  showGlobalCTA?: boolean;
  extraSchemas?: any[];
}

const { metadata = {}, showGlobalCTA = true, extraSchemas = [] } = Astro.props;
const localizedMetadata = localizeMetadata(metadata);

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const autoCanonical =
  new URL(pathname, siteConfig.seo.siteUrl).href.replace(/\/$/, "") ||
  siteConfig.seo.siteUrl;

const {
  title = siteConfig.seo.defaultTitle,
  description = siteConfig.seo.defaultDescription,
  keywords = siteConfig.seo.keywords,
  image = siteConfig.seo.ogImage,
  canonical = autoCanonical,
  noindex,
  nofollow,
} = localizedMetadata;

// ─── Auto Breadcrumbs ────────────────────────────────────────────────────────
const ORPHAN_SEGMENTS = new Set(["solutions", "indoor-billboards", "locations"]);
const segments = pathname === "/" ? [] : pathname.split("/").filter(Boolean);
const crumbs: Array<{ name: string; url: string }> = [{ name: "Home", url: "/" }];
segments.forEach((seg: string, i: number) => {
  if (ORPHAN_SEGMENTS.has(seg) && i < segments.length - 1 && seg !== "solutions" && seg !== "locations") return;
  const url = "/" + segments.slice(0, i + 1).join("/");
  const name = seg
    .split("-")
    .map((w: string) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
  crumbs.push({ name, url });
});

// ─── Schemas ─────────────────────────────────────────────────────────────────
const baseSchemas: any[] = [
  organizationSchema(),
  brandOrganizationSchema(),
  websiteSchema(),
  webPageSchema({
    url: pathname,
    name: title,
    description,
    image,
  }),
];
if (crumbs.length > 1) baseSchemas.push(breadcrumbSchema(crumbs));
const allSchemas = [...baseSchemas, ...extraSchemas];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={siteConfig.colors.primary} />

    {/* Astro 6 Fonts API — handles preload, font-face, and fallback metrics */}
    <Font cssVariable="--font-poppins" preload />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    {nofollow && <meta name="robots" content="nofollow" />}

    {/* Favicon */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteConfig.seo.siteName} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
    {siteConfig.seo.twitterHandle && <meta name="twitter:site" content={siteConfig.seo.twitterHandle} />}

    {/* JSON-LD schemas — one script per entity */}
    {allSchemas.map((s) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(s)} />
    ))}

    {/* Inline critical CSS for faster LCP */}
    <style is:inline define:vars={{ fontPoppins: "var(--font-poppins)" }}>
      body{font-family:var(--font-poppins),-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;margin:0}
      h1{font-size:2.25rem;font-weight:700;line-height:1.25;color:#111827}
      @media(min-width:640px){h1{font-size:3rem}}
      @media(min-width:768px){h1{font-size:3rem}}
      @media(min-width:1024px){h1{font-size:3.75rem}}
    </style>

    <ClientRouter />
  </head>
  <body class="antialiased text-gray-900 bg-white">
    <Header />
    <main>
      <slot />
    </main>

    {
      showGlobalCTA && (
        <CallToAction
          title="Ready to Grow Your Business?"
          subtitle="Let's create a marketing strategy that delivers results. Contact us today for a free consultation."
          background="primary"
          actions={[
            {
              text: "Get Started Today",
              href: "/contact-us",
              variant: "primary",
            },
          ]}
        />
      )
    }

    <Footer />
    <ScrollAnimations />
  </body>
</html>
