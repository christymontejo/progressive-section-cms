---
import PageLayout from "~/layouts/PageLayout.astro";
import CallToAction from "~/components/sections/CallToAction.astro";
import Hero from "~/components/sections/Hero.astro";
import FAQs from "~/components/sections/FAQs.astro";
import ContentWithImage from "~/components/sections/ContentWithImage.astro";
import ContentWithVideo from "~/components/sections/ContentWithVideo.astro";
import CTALight from "~/components/sections/CTALight.astro";
import FeaturesSection from "~/components/sections/FeaturesSection.astro";
import FeaturesWithImage from "~/components/sections/FeaturesWithImage.astro";
import NetworksSection from "~/components/sections/NetworksSection.astro";
import FormSection from "~/components/sections/FormSection.astro";

import connectedTvData from "~/data/pages/connected-tv.json";
import displayGeofencingData from "~/data/pages/display-geofencing.json";
import streamingAudioData from "~/data/pages/streaming-audio.json";
import { localizeData } from "~/config/site";
import { buildPageMeta } from "~/lib/pageMeta";

const dataMap: Record<string, any> = localizeData({
  "connected-tv": connectedTvData,
  "display-geofencing": displayGeofencingData,
  "streaming-audio": streamingAudioData,
});

const SERVICE_TYPE: Record<string, string> = {
  "connected-tv": "Advertising",
  "display-geofencing": "Advertising",
  "streaming-audio": "Advertising",
};

export function getStaticPaths() {
  return [
    { params: { slug: "connected-tv" } },
    { params: { slug: "display-geofencing" } },
    { params: { slug: "streaming-audio" } },
  ];
}

const { slug } = Astro.params;
const entry = dataMap[slug!];

const sections = (entry.sections || []).sort(
  (a: any, b: any) => (a.order || 0) - (b.order || 0)
);

const { metadata, extraSchemas } = buildPageMeta(entry, {
  service: {
    url: `/solutions/branding-awareness/${slug}`,
    serviceType: SERVICE_TYPE[slug!],
  },
});
---

<PageLayout metadata={metadata} extraSchemas={extraSchemas}>
  {
    sections.map((section: any) => {
      // Hero Section
      if (section.section === "Hero") {
        return (
          <Hero
            tagline={section.eyebrow}
            title={section.title}
            subtitle={section.description}
            image={section.image}
            actions={
              section.ctaText && section.ctaLink
                ? [
                    {
                      text: section.ctaText,
                      href: section.ctaLink,
                      variant: "primary",
                    },
                  ]
                : []
            }
          />
        );
      }

      // FAQs Section
      if (section.section === "FAQs" && section.faqs) {
        return (
          <FAQs
            title={section.title}
            faqs={section.faqs}
            background={section.background}
          />
        );
      }

      // ContentWithImage Section
      if (section.section === "ContentWithImage") {
        return (
          <ContentWithImage
            title={section.title}
            eyebrow={section.eyebrow}
            description={section.description}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            image={section.image}
            imagePosition={section.imagePosition}
            background={section.background}
          />
        );
      }

      // ContentWithVideo Section
      if (section.section === "ContentWithVideo") {
        return (
          <ContentWithVideo
            title={section.title}
            eyebrow={section.eyebrow}
            description={section.description}
            videoUrl={section.videoUrl}
            background={section.background}
          />
        );
      }

      // CTALight Section
      if (section.section === "CTALight") {
        return (
          <CTALight
            title={section.title}
            description={section.description}
            ctaText={section.ctaText || "Get in Touch"}
            ctaLink={section.ctaLink || "/contact"}
          />
        );
      }

      // Features Sections
      if (
        section.section === "FeaturesWithImage" ||
        section.section === "FeaturesSection"
      ) {
        if (!section.features) return null;

        if (section.section === "FeaturesWithImage") {
          return (
            <FeaturesWithImage
              eyebrow={section.eyebrow}
              title={section.title}
              description={section.description}
              cards={section.features}
              ctaText={section.ctaText}
              ctaLink={section.ctaLink}
              background={section.background}
              isCarousel={section.isCarousel}
              itemsPerSlide={section.itemsPerSlide}
              carouselAutoplay={section.carouselAutoplay}
              carouselAutoplayDelay={section.carouselAutoplayDelay}
            />
          );
        }

        return (
          <FeaturesSection
            eyebrow={section.eyebrow}
            title={section.title}
            description={section.description}
            features={section.features}
            ctaText={section.ctaText}
            ctaLink={section.ctaLink}
            background={section.background}
          />
        );
      }

      // Networks Section (for streaming platforms, etc.)
      if (section.section === "Networks" && section.networks) {
        return (
          <NetworksSection
            title={section.title}
            subtitle={section.subtitle}
            description={section.description}
            networks={section.networks}
          />
        );
      }

      // Form Section
      if (section.section === "Form" && section.formFields) {
        return (
          <FormSection
            title={section.title}
            subtitle={section.eyebrow}
            description={section.description}
            fields={section.formFields}
            submitText={section.submitText}
            submitAction={section.submitAction}
            background={section.background}
          />
        );
      }

      return null;
    })
  }
</PageLayout>
