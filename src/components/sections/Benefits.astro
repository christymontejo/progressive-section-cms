---
import { Icon } from "astro-icon/components";

interface Benefit {
  title: string;
  description: string;
}

interface Props {
  title?: string;
  description?: string;
  benefits?: Benefit[];
}

const {
  title = "Digital Marketing Experts Near You Serving Aurora",
  description = "Looking to grow your business in Aurora? Our local digital marketing agency specializes in helping businesses stand out through targeted strategies that drive results. Whether you're looking to increase foot traffic, grow your online presence, or run high-converting ad campaigns, we offer tailored solutions backed by experience and data.",
  benefits = [],
} = Astro.props;
---

<section class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white fade-in-section">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="max-w-4xl mb-12 md:mb-16 benefits-content animate-on-scroll animate-fade-in-up">
      {title && (
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 tracking-tight mb-6">
          {title}
          <span class="inline-block w-2 h-2 md:w-2.5 md:h-2.5 bg-[#00bba9] rounded-full align-super ml-1"></span>
        </h2>
      )}
      {description && (
        <div class="text-base md:text-lg text-gray-700 leading-relaxed" set:html={description}>
        </div>
      )}
    </div>

    {/* Benefits Cards */}
    {benefits.length > 0 && (
      <div class="space-y-6">
        <div class="mb-10">
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 inline-flex items-center gap-3">
            <span class="w-1.5 h-8 bg-[#00bba9] rounded-full"></span>
            Key Benefits of Working With Us:
          </h3>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6 animate-stagger">
          {benefits.map((benefit, index) => (
            <div 
              class="relative p-6 md:p-8 rounded-2xl bg-white border border-gray-200 overflow-hidden"
            >
              {/* Decorative gradient overlay */}
              <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0"></div>
              
              {/* Number badge */}
              <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center">
                <span class="text-sm font-bold text-gray-400">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
              </div>
              
              {/* Content */}
              <div class="relative space-y-3">
                <div class="text-xl md:text-2xl font-bold text-gray-900 leading-tight pr-12">
                  {benefit.title}
                </div>
                <p class="text-base text-gray-600 leading-relaxed">
                  {benefit.description}
                </p>
              </div>
              
              {/* Bottom accent line */}
              <div class="absolute bottom-0 left-0 h-1 bg-gradient-to-r from-primary to-primary/50 w-0"></div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .benefits-content :global(a) {
    color: inherit;
    text-decoration: none;
    font-weight: 700;
  }

  .benefits-content :global(strong) {
    font-weight: 700;
  }

  /* Optimize rendering performance */
  section {
    will-change: auto;
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
</style>
